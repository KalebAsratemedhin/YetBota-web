# YetBota backend
#
# Local stack (infra + app services + API gateway):
#   docker compose --env-file .env up -d --build
# Reset volumes:
#   docker compose --env-file .env down -v
#
# Frontend talks to the gateway only (default http://localhost:8080):
#   /proxy/main/...    -> identity-service
#   /proxy/content/... -> content-service
#   /proxy/ai/...      -> ai-service
#
# Render: deploy each folder as a Docker Web Service.
#   identity-service/  content-service/  ai-service/  api-gateway/
# For identity + ai on Render, use Dockerfile.render (Neo4j bundled in the same container).
# Set neo4jURI=bolt://localhost:7687 (default in Dockerfile.render).
# On api-gateway, set:
#   IDENTITY_UPSTREAM=https://<identity>.onrender.com
#   CONTENT_UPSTREAM=https://<content>.onrender.com
#   AI_UPSTREAM=https://<ai>.onrender.com
# Set NEXT_PUBLIC_API_URL on the frontend to the gateway URL.
# Set corsHosts on each app service to your frontend origin (e.g. https://app.example.com).
#
# CI/CD (GitHub Actions -> Docker Hub):
#   Add repo secrets: DOCKERHUB_USERNAME, DOCKERHUB_TOKEN
#   Workflow: .github/workflows/docker-publish.yml (runs on push to main)
#   Images pushed as:
#     <DOCKERHUB_USERNAME>/yetbota-identity-service:latest
#     <DOCKERHUB_USERNAME>/yetbota-ai-service:latest
#     <DOCKERHUB_USERNAME>/yetbota-content-service:latest
#     <DOCKERHUB_USERNAME>/yetbota-api-gateway:latest
#
# Render (pull pre-built images from Docker Hub):
#   identity-service  -> yetbota-identity-service  (Neo4j bundled; set neo4j creds + internalServiceToken)
#   ai-service        -> yetbota-ai-service        (Neo4j bundled)
#   content-service   -> yetbota-content-service   (no Neo4j; set identityServiceUrl + aiServiceUrl)
#   api-gateway       -> yetbota-api-gateway
#   Use "Deploy an existing image from a registry" and the :latest or :<git-sha> tag.

# API gateway (api-gateway/)
GATEWAY_PORT=8080
IDENTITY_UPSTREAM=http://identity-service:6699
CONTENT_UPSTREAM=http://content-service:9966
AI_UPSTREAM=http://ai-service:8989

# Service-to-service graph APIs (content -> identity + ai)
identityServiceUrl=http://identity-service:6699
aiServiceUrl=http://ai-service:8989
internalServiceToken=dev-internal-token

# Postgres (app database)
postgresHost=localhost
postgresPort=5432
postgresUser=yetbota
postgresPassword=yetbota
postgresDB=yetbota
postgresSslMode=disable

# Redis
redisAddress=localhost:6379
redisPassword=redis
redisPoolTimeout=4s
redisIdleTimeout=5m
redisReadTimeout=3s
redisWriteTimeout=3s

# Neo4j
neo4jURI=bolt://localhost:7687
neo4jUsername=neo4j
neo4jPassword=neo4jpass

# RabbitMQ
rabbitmqUrl=amqp://guest:guest@localhost:5672/
rabbitmqUser=guest
rabbitmqPassword=guest

# Weaviate (ai-service only)
weaviateUrl=
weaviateApiKey=

# Gemini (ai-service only)
geminiApiKey=

# JWT (identity + content)
jwtAccessTokenSecret=
jwtRefreshTokenSecret=
jwtAccessTokenExpiration=3600
jwtRefreshTokenExpiration=604800

# Cloudinary (identity + content)
cloudinaryCloudName=
cloudinaryAPIKey=
cloudinaryAPISecret=

# Shared
corsHosts=http://localhost:3000
debug=true
