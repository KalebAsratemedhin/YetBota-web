# YetBota backend — unified deployment
#
# Copy to .env and fill in secrets. Shared by identity, content, and ai services.
#
# Local infra: docker compose --env-file .env up -d
# Run API:      docker build -t yetbota-backend . && docker run --env-file .env -p 8080:8080 yetbota-backend

# Postgres (Neon)
postgresHost=
postgresPort=5432
postgresUser=
postgresPassword=
postgresDB=yetbota

# Temporal metadata DB (Neon — separate database recommended)
POSTGRES_SEEDS=
POSTGRES_USER=
POSTGRES_PWD=

# Redis
redisAddress=localhost:6379
redisPassword=redis
redisPoolTimeout=4s
redisIdleTimeout=5m
redisReadTimeout=3s
redisWriteTimeout=3s

# Neo4j
neo4jURI=bolt://localhost:7687
neo4jUsername=neo4j
neo4jPassword=neo4jpass

# Temporal
temporalHost=localhost:7233
temporalNamespace=default

# Weaviate (ai-service only)
weaviateUrl=
weaviateApiKey=

# Gemini (ai-service only)
geminiApiKey=

# JWT (identity + content)
jwtAccessTokenSecret=
jwtRefreshTokenSecret=
jwtAccessTokenExpiration=3600
jwtRefreshTokenExpiration=604800

# Cloudinary (identity + content)
cloudinaryCloudName=
cloudinaryAPIKey=
cloudinaryAPISecret=

# Firebase push (content)
firebaseProjectID=
firebaseClientEmail=
firebasePrivateKey=

# Shared
corsHosts=http://localhost:3000
debug=true

# docker-compose only (not read by app services)
REDIS_PASSWORD=redis
REDIS_PORT=6379
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233
